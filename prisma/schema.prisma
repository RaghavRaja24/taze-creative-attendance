generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum LeaveType {
  CASUAL
  SICK
  PAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                String            @id @default(cuid())
  name              String
  email             String            @unique
  image             String?
  role              Role              @default(EMPLOYEE)
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  accounts          Account[]
  sessions          Session[]
  attendanceRecords AttendanceRecord[]
  holidaysCreated   Holiday[]
  leaveRequests     LeaveRequest[]    @relation("LeaveRequester")
  reviewedLeaves    LeaveRequest[]    @relation("LeaveReviewer")
  archivedLeaves    LeaveRequest[]    @relation("LeaveArchiver")
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  checkInAt  DateTime?
  checkOutAt DateTime?
  late       Boolean  @default(false)
  isManual   Boolean  @default(false)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  type         LeaveType
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String
  status       LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?       @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  reviewNote   String?
  isArchived   Boolean     @default(false)
  archivedAt   DateTime?
  archivedById String?
  archivedBy   User?       @relation("LeaveArchiver", fields: [archivedById], references: [id], onDelete: SetNull)
  archiveReason String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([userId, startDate, endDate])
  @@index([isArchived])
}

model Holiday {
  id            String   @id @default(cuid())
  name          String
  date          DateTime @db.Date
  financialYear String
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@unique([date])
  @@index([financialYear, date])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
